# Este arquivo guarda apenas configuracoes nao sensiveis.
# Nao coloque API keys aqui.

COMPOSE_PROJECT_NAME=openclaw-personal-gateway

# Imagem local buildada a partir de ./vendor/openclaw.
OPENCLAW_IMAGE=openclaw:local
OPENCLAW_INSTALL_DOCKER_CLI=1

# Browser local gerenciado para automacao web no perfil WhatsApp dedicado + browser.
OPENCLAW_INSTALL_BROWSER=0

# Sandbox Docker para execucao de tools em container separado.
OPENCLAW_SANDBOX_ENABLE=1
OPENCLAW_SANDBOX_IMAGE=openclaw-sandbox:bookworm-slim
OPENCLAW_DOCKER_SOCKET_PATH=/var/run/docker.sock

# Portas publicadas no host.
OPENCLAW_HOST_PORT=18789
OPENCLAW_BRIDGE_HOST_PORT=18790

# Configuracao do gateway alinhada ao compose oficial do OpenClaw.
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan

# Timezone operacional do container.
OPENCLAW_TZ=America/Bahia

# Nivel de log do container.
OPENCLAW_LOG_LEVEL=info
